{
  "info": {
    "name": "LoanWise API Collection",
    "description": "Complete API collection for the Loan Eligibility Checker application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "loanId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@123\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["var data = pm.response.json();\npm.collectionVariables.set('token', data.token);"] }
          }]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@loancheck.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["var data = pm.response.json();\npm.collectionVariables.set('adminToken', data.token);"] }
          }]
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/profile",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employmentType\": \"salaried\",\n  \"monthlyIncome\": 75000,\n  \"existingEMIs\": 5000,\n  \"cibilScore\": 750\n}"
            }
          }
        }
      ]
    },
    {
      "name": "EMI Calculator",
      "item": [
        {
          "name": "Calculate EMI",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/emi/calculate",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loanAmount\": 500000,\n  \"tenure\": 36,\n  \"purpose\": \"personal\",\n  \"cibilScore\": 750\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Loans",
      "item": [
        {
          "name": "Submit Loan Application",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/loans",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loanAmount\": 500000,\n  \"purpose\": \"personal\",\n  \"tenure\": 36\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["var data = pm.response.json();\nif(data.application) pm.collectionVariables.set('loanId', data.application._id);"] }
          }]
        },
        {
          "name": "Get My Applications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/loans",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Single Application",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/loans/{{loanId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Get All Applications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/applications",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Get Applications (Filtered)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/applications?status=SUBMITTED&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "applications"],
              "query": [
                { "key": "status", "value": "SUBMITTED" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Approve Application",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/admin/applications/{{loanId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\",\n  \"adminNote\": \"Application approved after manual review\"\n}"
            }
          }
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/admin/applications/{{loanId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"REJECTED\",\n  \"adminNote\": \"Insufficient documentation provided\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    }
  ]
}
